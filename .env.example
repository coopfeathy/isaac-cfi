# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (optional)
# Set to 1 to enable destination charges.
# Primary routing comes from DB table: stripe_connect_payout_rules.
# Run supabase/RULES.sql to insert default catch-all rules.
# The env vars below are a secondary fallback when no DB rule matches.
STRIPE_CONNECT_ENABLED=1
# Fallback destination account used when no DB payout rule matches.
# Must be set (or DB rules must exist) whenever STRIPE_CONNECT_ENABLED=1.
STRIPE_CONNECT_DEFAULT_DESTINATION_ACCOUNT=acct_1FbdK6Cus0IiI5gg
# The Stripe platform (self) account. Split-transfer buckets that target this
# account are skipped at transfer time — Stripe rejects transfers.create when
# destination equals the platform, and funds already live there. Defaults to
# STRIPE_CONNECT_DEFAULT_DESTINATION_ACCOUNT if unset.
STRIPE_CONNECT_PLATFORM_ACCOUNT_ID=acct_1FbdK6Cus0IiI5gg
# Optional per-transaction-type overrides (leave unset to use the default above)
# STRIPE_CONNECT_DISCOVERY_FLIGHT_DESTINATION_ACCOUNT=
# STRIPE_CONNECT_WEBSITE_TRANSACTION_DESTINATION_ACCOUNT=
# STRIPE_CONNECT_DEFAULT_PLATFORM_FEE_BPS=
# STRIPE_CONNECT_DEFAULT_PLATFORM_FEE_CENTS=

# Optional additional developer payout (transferred on payment_intent.succeeded)
# For discovery flights, applied BPS = WEBSITE + DISCOVERY bonus.
# Discovery flight in admin billing is identified by exact item name: "Discovery Flight".
# Set developer connected account ID explicitly before enabling in production.
STRIPE_CONNECT_DEVELOPER_DESTINATION_ACCOUNT=acct_1TEH7GENasfvDHGO
STRIPE_CONNECT_DEVELOPER_WEBSITE_TRANSACTION_BPS=100
STRIPE_CONNECT_DEVELOPER_DISCOVERY_FLIGHT_BPS=1000

# Resend
RESEND_API_KEY=re_...

# Twilio (required only for SMS checkout link delivery)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
ACCOUNTANT_PHONE=+15557654321
# Number of days included in accountant purchase/expense text summary
ACCOUNTANT_TEXT_LOOKBACK_DAYS=7

# Google Reviews (Places API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PLACE_ID=your-google-business-place-id

# App
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
ADMIN_EMAIL=your-admin-email@gmail.com
BOOKING_PENDING_TIMEOUT_MINUTES=30
ALERT_RECIPIENT_EMAIL=ops@your-domain.com
ALERT_MIN_AGE_MINUTES=15
ALERT_EMAIL_COOLDOWN_MINUTES=60
WEBHOOK_FAILURE_LOOKBACK_MINUTES=1440
# Homework email auto-send delay after lesson completion
HOMEWORK_EMAIL_DELAY_MINUTES=60

# Auto-generate Discovery Flight Slots (Netlify scheduled function)
# Days of week to create slots: 0=Sunday, 1=Monday, ..., 6=Saturday (comma-separated)
# Example: "0,6" = every Saturday and Sunday
DISCOVERY_SLOT_ACTIVE_WEEKDAYS=0,6
# Comma-separated start times in HH:MM 24-hour format (Eastern time)
# Example: "10:00" or "09:00,13:00" for multiple slots per active day
DISCOVERY_SLOT_TEMPLATE_TIMES=10:00
# Length of each discovery flight slot in minutes
DISCOVERY_SLOT_DURATION_MINUTES=90
# Price in cents (e.g. 25000 = $250.00)
DISCOVERY_SLOT_PRICE_CENTS=25000
# Total days ahead to maintain slots (rolling window)
DISCOVERY_SLOT_GENERATION_DAYS_AHEAD=30
# Minimum days in the future before a slot is created (e.g. 2 = never create for tomorrow)
DISCOVERY_SLOT_MIN_DAYS_OUT=1

# E-sign (DocuSeal default)
ESIGN_PROVIDER=docuseal
DOCUSEAL_FORM_URL=https://your-docuseal-host/d/your-template-slug
ESIGN_WEBHOOK_SECRET=choose-a-long-random-secret
# Set your DocuSeal webhook URL to:
# https://your-site.netlify.app/api/onboarding/esign-webhook?secret=choose-a-long-random-secret

# Optional Dropbox Sign fallback (only if using ESIGN_PROVIDER=dropbox_sign)
DROPBOX_SIGN_API_KEY=...
DROPBOX_SIGN_CLIENT_ID=...
DROPBOX_SIGN_TEMPLATE_ID=...
DROPBOX_SIGN_SIGNER_ROLE=Student
DROPBOX_SIGN_TEST_MODE=1
DROPBOX_SIGN_REDIRECT_URL=https://your-site.netlify.app/onboarding